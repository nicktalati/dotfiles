# Carbonfox theme for neomutt (thanks Claude)

# Basic colors
color normal        default default
color error         color204 default              # red (#EE5396 ≈ 204)
color message       color117 default              # cyan (#33B1FF ≈ 117)
color status        color249 color236             # fg2 on bg0
color indicator     standout default default

# Sidebar
color sidebar_indicator standout default default
color sidebar_highlight bold default color239
color sidebar_unread    color114 default          # green (#25be6a ≈ 114)
color sidebar_flagged   color141 default

# Index
color index         color249 default "~R"         # read messages
color index         color114 default "~U"         # unread
color index         color204 default "~D"         # deleted
color index         color141 default "~F"         # flagged

# Headers
color hdrdefault    color141 default              # magenta (#BE95FF ≈ 141)
color header        color117 default "^From:"
color header        color117 default "^To:"
color header        color117 default "^Subject:"
color header        color249 default "^Date:"

# Body
color quoted        color141 default              # magenta
color quoted1       color117 default              # cyan
color quoted2       color114 default              # green
color signature     color243 default              # comment/grey
color attachment    color215 default              # orange (#3DDBD9 ≈ 80, but using warmer)
color tilde         color236 default

# URLs
color body          color111 default "(https?|ftp)://[^ ]+"

# Lynx-style references [1], [2], etc.
color body          color111 default "\\[[0-9]+\\]"
