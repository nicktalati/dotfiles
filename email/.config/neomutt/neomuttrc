set folder = "~/mail"
set spoolfile = "+nicktalati/Inbox"
set mailcap_path = ~/.config/neomutt/mailcap

set realname = "Nick Talati"
set from = "UNCONFIGURED"
set sendmail = "/bin/false"

set mail_check = 5
set mail_check_stats = yes
set mail_check_stats_interval = 5

set use_threads = threads

set wait_key = no

set index_format = "%4C %Z %{%b %d} %-20.20L %s"
set sort = reverse-date
set markers = no

set sidebar_visible = yes
set sidebar_width = 25
set sidebar_format = "%D%* %?N?%N?"
set sidebar_non_empty_mailbox_only = yes

set mime_forward = yes
set mime_forward_rest = yes

auto_view text/html text/calendar application/ics
alternative_order text/calendar text/plain text/html

bind index,pager \Ck sidebar-prev
bind index,pager \Cj sidebar-next
bind index,pager \Co sidebar-open
bind index T tag-thread
bind index \Ct tag-pattern

bind pager j next-line
bind pager k previous-line

macro attach B "<pipe-entry>cat > /tmp/mail.html && xdg-open /tmp/mail.html<enter>"
macro index,pager U "<pipe-message>urlscan<enter>"
macro index S "<sync-mailbox><shell-escape>mbsync -a &>/dev/null &<enter>"

