#!/bin/bash

readonly vault="$HOME/crypt"
readonly reading="$HOME/reading"
readonly dest="/mnt/backup"

if ! mountpoint -q "/mnt/backup"; then
    echo "Drive not mounted. Run 'mount_drive' first"
    exit 1
fi

echo "Starting backup..."

mkdir -p "$dest"

echo "Syncing vault..."
rsync -av --delete "$vault/" "$dest/crypt/"
echo "Syncing reading..."
rsync -av --delete "$reading/" "$dest/reading/"

echo "Backup complete."
sync
